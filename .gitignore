# Backups written by sync-from-source --apply
.sync-backup/

# Backups written by sync-from-upstream --apply (downstream projects)
.scaffold-sync-backup/

# macOS
.DS_Store

# Local-only integration marker (created deliberately in the integration worktree)
.claude/integration-allow.local

# Local-only Claude Code settings (per-machine permissions/overrides)
.claude/settings.local.json

# Migration helpers: backups and state written by migrate_roadmap_issues.py
.claude/cache/

# Pristine generation-source folder (populated at bootstrap/sync time; not committed)
.grimoire-source/

# Transient sync-deps staging dir (cleaned per run)
.sync-deps-staging/

# Node / frontend build
node_modules/
dist/
*.tsbuildinfo

# Visual-inspection capture artifacts (W18; regenerated by `recipe.py smoke`/`inspect`)
artifacts/

# Rust / Tauri build
src-tauri/target/
src-tauri/gen/
.claude/worktrees/
