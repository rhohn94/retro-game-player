{
  "name": "harmony",
  "version": "0.21.0",
  "private": true,
  "type": "module",
  "description": "Harmony — a Mac-native (Apple Silicon) emulator frontend / launcher.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspect": "node scripts/visual-inspect.mjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@emulatorjs/emulatorjs": "^4.2.3",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "framer-motion": "^11.11.17",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@tauri-apps/cli": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.16.0",
    "playwright-core": "^1.61.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
